# ===========================================
# Uni-Proxy-Manager - Production Environment
# ===========================================
# Copy this file to .env and configure all required values

# ===========================================
# REQUIRED: Database Configuration
# ===========================================
# PostgreSQL credentials - CHANGE THESE!
POSTGRES_USER=uni_proxy_manager
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD
POSTGRES_DB=uni_proxy_manager

# ===========================================
# REQUIRED: Application URL
# ===========================================
# The public URL where the dashboard will be accessible
# Example: https://proxy-manager.yourdomain.com
UNI_PROXY_MANAGER_URL=http://localhost:3000

# ===========================================
# Docker Image Configuration
# ===========================================
# Registry where your images are hosted
IMAGE_REGISTRY=ghcr.io/your-org

# Image tag to use (latest, v1.0.0, etc.)
IMAGE_TAG=latest

# ===========================================
# Port Configuration
# ===========================================
# HAProxy ports
HAPROXY_HTTP_PORT=80
HAPROXY_HTTPS_PORT=443
HAPROXY_STATS_PORT=8404

# Dashboard port
DASHBOARD_PORT=3000

# ===========================================
# SSL/TLS Certificate Configuration
# ===========================================
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@yourdomain.com

# Set to true to use Let's Encrypt staging (for testing)
# Set to false for production certificates
ACME_STAGING=false

# ===========================================
# DNS Provider: Cloudflare (Optional)
# ===========================================
# Required for DNS-01 challenges with Cloudflare-managed domains
# Create an API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:DNS:Edit
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ===========================================
# DNS Provider: Namecheap (Optional)
# ===========================================
# Required for DNS-01 challenges with Namecheap-managed domains
# Enable API access at: https://ap.www.namecheap.com/settings/tools/apiaccess/
# NAMECHEAP_API_USER=your-namecheap-username
# NAMECHEAP_API_KEY=your-namecheap-api-key
# NAMECHEAP_CLIENT_IP=your-whitelisted-ip

# ===========================================
# Resource Limits
# ===========================================
# Redis maximum memory
REDIS_MAXMEMORY=256mb
