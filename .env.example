# ===========================================
# Uni-Proxy-Manager Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# Supports _FILE suffix for Docker secrets (e.g., UNI_PROXY_MANAGER_DB_URL_FILE)

# Application
UNI_PROXY_MANAGER_URL=http://localhost
UNI_PROXY_MANAGER_API_PORT=3001

# ===========================================
# SECURITY CONFIGURATION (REQUIRED FOR PRODUCTION)
# ===========================================
# Generate secrets using: openssl rand -base64 32

# API Authentication
# All API endpoints (except /health) require Bearer token authentication
UNI_PROXY_MANAGER_API_KEY=
UNI_PROXY_MANAGER_AUTH_ENABLED=true

# HAProxy Stats Page Protection
# If password is set, stats page requires authentication
# If empty, stats page is restricted to localhost only
UNI_PROXY_MANAGER_STATS_USER=admin
UNI_PROXY_MANAGER_STATS_PASSWORD=

# Redis Authentication (optional but recommended for production)
# Set this password and update REDIS_URL to include it
# Format: redis://:yourpassword@redis:6379
UNI_PROXY_MANAGER_REDIS_PASSWORD=
# When using password auth, set the full URL:
# UNI_PROXY_MANAGER_REDIS_URL=redis://:${UNI_PROXY_MANAGER_REDIS_PASSWORD}@redis:6379

# ===========================================
# Database (PostgreSQL)
# ===========================================
UNI_PROXY_MANAGER_DB_URL=postgresql://uni_proxy_manager:changeme@localhost:5432/uni_proxy_manager
# UNI_PROXY_MANAGER_DB_URL_FILE=/run/secrets/db_url

# Redis (for password auth, use: redis://:yourpassword@redis:6379)
UNI_PROXY_MANAGER_REDIS_URL=redis://localhost:6379
# UNI_PROXY_MANAGER_REDIS_URL_FILE=/run/secrets/redis_url

# HAProxy
UNI_PROXY_MANAGER_HAPROXY_SOCKET=/var/run/haproxy/haproxy.sock
UNI_PROXY_MANAGER_HAPROXY_CONFIG_PATH=/data/haproxy/haproxy.cfg

# File Storage Paths
UNI_PROXY_MANAGER_CERTS_DIR=/data/certificates
UNI_PROXY_MANAGER_ERROR_PAGES_DIR=/data/error-pages

# Let's Encrypt / ACME
UNI_PROXY_MANAGER_ACME_EMAIL=admin@example.com
UNI_PROXY_MANAGER_ACME_STAGING=true

# Docker Compose specific (used in docker-compose.yml)
POSTGRES_USER=uni_proxy_manager
POSTGRES_PASSWORD=changeme
POSTGRES_DB=uni_proxy_manager

# ===========================================
# Sites Extension (optional)
# ===========================================
# Enable the sites extension for web app hosting
UNI_PROXY_MANAGER_SITES_ENABLED=false

# OpenRuntimes Executor (REQUIRED for sites extension)
# Generate a secure secret: openssl rand -base64 32
SITES_EXECUTOR_ENDPOINT=http://openruntimes-executor:80
SITES_EXECUTOR_SECRET=

# Sites-lookup cache invalidation authentication
# Uses UNI_PROXY_MANAGER_API_KEY by default, or set a separate secret
# SITES_INVALIDATE_SECRET=

# Storage directories for sites
SITES_BUILD_DIR=/tmp/builds
SITES_ARTIFACTS_DIR=/data/sites/artifacts
SITES_STORAGE_DIR=/storage/functions
SITES_SOURCE_DIR=/data/sites/sources

# Build resource defaults (for executor-based builds)
SITES_BUILD_CPUS_DEFAULT=1.0
SITES_BUILD_MEMORY_MB_DEFAULT=2048
SITES_BUILD_TIMEOUT_SECONDS_DEFAULT=900

# Runtime startup timeout (seconds to wait for container ready)
SITES_RUNTIME_STARTUP_TIMEOUT_SECONDS=120

# Route cache TTL (seconds) - how long to cache site routing info
SITES_CACHE_TTL=60

# GitHub App (optional, for repository integration)
# UNI_PROXY_MANAGER_GITHUB_APP_ID=
# UNI_PROXY_MANAGER_GITHUB_APP_PRIVATE_KEY=
# UNI_PROXY_MANAGER_GITHUB_WEBHOOK_SECRET=
