{
  "name": "@uni-proxy-manager/analytics",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && bun scripts/copy-non-ts-files.js",
    "start": "node dist/index.js",
    "start:bun": "bun run dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@hono/zod-validator": "^0.7.6",
    "@uni-proxy-manager/database": "workspace:*",
    "@uni-proxy-manager/queue": "workspace:*",
    "@uni-proxy-manager/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.71.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "ioredis": "5.10.0",
    "jose": "^5.10.0",
    "nanoid": "^5.1.7",
    "ua-parser-js": "^2.0.9",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
