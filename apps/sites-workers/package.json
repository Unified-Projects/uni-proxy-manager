{
  "name": "@uni-proxy-manager/sites-workers",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external playwright --external playwright-core",
    "start": "bun run dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@uni-proxy-manager/database": "workspace:*",
    "@uni-proxy-manager/queue": "workspace:*",
    "@uni-proxy-manager/shared": "workspace:*",
    "bullmq": "^5.71.0",
    "ioredis": "5.10.0",
    "playwright": "^1.58.2",
    "tar": "^7.5.12"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/tar": "^7.0.87",
    "typescript": "^5.9.3"
  }
}
