{
  "name": "uni-proxy-manager",
  "version": "0.1.1",
  "private": true,
  "license": "AGPL-3.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "eslint . && pnpm --filter @uni-proxy-manager/web lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:unit:watch": "vitest watch --config vitest.config.unit.ts",
    "test:unit:ui": "vitest --ui --config vitest.config.unit.ts",
    "test:unit:coverage": "vitest run --coverage --config vitest.config.unit.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "vitest watch --config vitest.config.integration.ts",
    "test:integration:ui": "vitest --ui --config vitest.config.integration.ts",
    "test:integration:coverage": "vitest run --coverage --config vitest.config.integration.ts",
    "test:docker:up": "docker compose -f docker/docker-compose.test.yml up -d --wait --build",
    "test:docker:down": "docker compose -f docker/docker-compose.test.yml down -v",
    "test:docker:logs": "docker compose -f docker/docker-compose.test.yml logs -f",
    "test:urt": "vitest run --config vitest.config.integration.ts tests/integration/openruntimes/urt-integration.test.ts",
    "test:urt:watch": "vitest watch --config vitest.config.integration.ts tests/integration/openruntimes/urt-integration.test.ts",
    "test:run-all": "bash scripts/test-integration.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e-real": "vitest run --config vitest.config.e2e-real.ts",
    "test:e2e-real:watch": "vitest watch --config vitest.config.e2e-real.ts",
    "test:e2e-real:up": "docker compose -f tests/e2e-real/setup/docker-compose.e2e.yml up -d --build",
    "test:e2e-real:down": "docker compose -f tests/e2e-real/setup/docker-compose.e2e.yml down -v",
    "test:e2e-real:logs": "docker compose -f tests/e2e-real/setup/docker-compose.e2e.yml logs -f",
    "visual-test:start": "bash scripts/visual-test-start.sh",
    "visual-test:stop": "bash scripts/visual-test-stop.sh",
    "visual-test:stop:cleanup": "bash scripts/visual-test-stop.sh --cleanup",
    "visual-test:logs": "docker compose -f docker/docker-compose.visual-test.yml logs -f",
    "visual-test:seed": "npx tsx scripts/seed-visual-test.ts",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @uni-proxy-manager/database db:studio",
    "dev:api": "turbo dev --filter=@uni-proxy-manager/api",
    "dev:web": "turbo dev --filter=@uni-proxy-manager/web",
    "dev:workers": "turbo dev --filter=@uni-proxy-manager/workers",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/bun": "^1.3.11",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "archiver": "^7.0.1",
    "bullmq": "^5.71.0",
    "drizzle-orm": "^0.45.1",
    "eslint": "^10.0.3",
    "hono": "^4.12.8",
    "ioredis": "5.10.0",
    "jsdom": "^25.0.1",
    "nanoid": "^5.1.7",
    "postgres": "^3.4.8",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "tar": ">=7.5.11",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "minimatch": ">=9.0.7",
      "axios@>=1.0.0 <2.0.0": ">=1.13.5",
      "lodash@>=4.0.0 <5.0.0": ">=4.17.23",
      "rollup@>=4.0.0 <5.0.0": ">=4.59.0",
      "ajv@<7.0.0": "6.14.0",
      "fast-xml-parser@>=5.0.0 <6.0.0": ">=5.3.8",
      "ioredis": "5.10.0"
    }
  }
}
